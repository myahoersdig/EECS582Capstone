<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_ranking_card_bad"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvRankTitle1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="#1 Worst:  Avg Focus Stability: X"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRankSubtitle1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="Location: X&#10;Music: X&#10;Lyrics: X&#10;Tempo: X&#10;Time: X&#10;Sessions used: X"
        android:textColor="#000000"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvRankTitle2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="#2 Worst: Avg Focus Stability: X"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRankSubtitle2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="Location: X&#10;Music: X&#10;Lyrics: X&#10;Tempo: X&#10;Time: X&#10;Sessions used: X"
        android:textColor="#000000"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvRankTitle3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="#3 Worst: Avg Focus Stability: X"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRankSubtitle3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="Location: X&#10;Music: X&#10;Lyrics: X&#10;Tempo: X&#10;Time: X&#10;Sessions used: X"
        android:textColor="#000000"
        android:textSize="14sp" />

</LinearLayout>
